# Copy this file to .env and fill in the values

# MySQL
MYSQL_DATABASE=kmrl
MYSQL_USER=kmrl
MYSQL_PASSWORD=kmrlpass
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_PORT_HOST=3306

# Application
SERVER_PORT_HOST=8091
BASE_URL=http://your-server-ip:8091
JWT_SECRET=replace-with-strong-random-secret

# Gmail SMTP (for sending mail)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_app_password

# Google OAuth (optional if you use OAuth login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://your-server-ip:8091/api/v1/login/oauth2/code/google

# AI service
ML_API_KEY=